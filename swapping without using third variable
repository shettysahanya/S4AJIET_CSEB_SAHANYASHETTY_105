class Main {
    public static void main(String[] args) {
        int a=20,b=10;
        int temp;
        System.out.println("before swapping a "+a );
        System.out.println("before swapping b "+b );
        a+=b;
        b=a-b;
        a-=b;
        System.out.println("after swapping a "+a);
        System.out.println("after swapping b "+b);
    }
}
