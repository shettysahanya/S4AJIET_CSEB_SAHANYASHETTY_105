public class OddEvenArray {
    public static void main(String[] args) {

        int[] numbers = {10, 15, 22, 33, 40, 55, 60};

        System.out.println("Even numbers:");
        for (int num : numbers) {
            if (num % 2 == 0) {
                System.out.println(num);
            }
        }

        System.out.println("Odd numbers:");
        for (int num : numbers) {
            if (num % 2 != 0) {
                System.out.println(num);
            }
        }
    }
}
